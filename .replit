modules = ["nodejs-20", "web", "postgresql-16"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "PocketBase"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "fuser -k 5000/tcp 2>/dev/null; sleep 1; npm run dev"
waitForPort = 5000

[[workflows.workflow]]
name = "PocketBase"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "fuser -k 8090/tcp 2>/dev/null; sleep 1; ./bin/pocketbase serve --http=0.0.0.0:8090 --dir=./pb_data"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8090
externalPort = 3000

[deployment]
deploymentTarget = "vm"
run = ["node", "dist/server.cjs"]
build = ["npm", "run", "build"]
