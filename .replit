modules = ["nodejs-20", "web"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "PocketBase"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "PocketBase"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "./bin/pocketbase serve --http=0.0.0.0:8090 --dir=./pb_data"

[[ports]]
localPort = 5000
externalPort = 5000

[[ports]]
localPort = 8090
externalPort = 3000

[[ports]]
localPort = 24678
externalPort = 80

[deployment]
deploymentTarget = "vm"
run = ["node", "dist/server.cjs"]
build = ["npm", "run", "build"]
